# Optional public Kayco CMS override. Production defaults to the hosted content API;
# if that API is unavailable, the site uses its bundled catalog.
VITE_KAYCO_CONTENT_API_URL="https://qkatfirzwukmgdrytbue.supabase.co/functions/v1/content-api"

# Public canonical origin used by route metadata and social sharing tags.
VITE_SITE_URL="https://tuscanini-site.vercel.app"

# Optional public HTTPS endpoint that accepts POST { "email": "..." }.
# When omitted, the newsletter section shows an honest unavailable state.
# If this uses another origin, allow that origin in vercel.json's connect-src policy.
# Never put a provider secret in a VITE_ variable.
VITE_NEWSLETTER_ENDPOINT=""
